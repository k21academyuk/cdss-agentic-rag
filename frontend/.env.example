# CDSS frontend public runtime configuration
# These values are safe for client-side delivery. Do not add secrets.

VITE_API_BASE_URL=https://your-cdss-api.<region>.azurecontainerapps.io/api
VITE_AZURE_CLIENT_ID=your-spa-client-id
VITE_AZURE_TENANT_ID=your-tenant-id
VITE_AZURE_AUTHORITY=https://login.microsoftonline.com/your-tenant-id
VITE_API_SCOPE=api://cdss-api/access_as_user
VITE_REDIRECT_URI=https://your-cdss-frontend.azurestaticapps.net
VITE_POST_LOGOUT_URI=https://your-cdss-frontend.azurestaticapps.net
VITE_WS_ENDPOINT=wss://your-cdss-pubsub.webpubsub.azure.com
VITE_ENVIRONMENT=development
VITE_USE_MOCK_API=true
