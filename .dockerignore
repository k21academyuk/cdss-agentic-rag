.github/
.gitlab-ci.yml
.azure-pipelines/

# OS files
.DS_Store
Thumbs.db

# Notebooks
*.ipynb
.ipynb_checkpoints/

# Logs
*.log
logs/

# Secrets and credentials
*.pem
*.key
*.crt
credentials/
secrets/
